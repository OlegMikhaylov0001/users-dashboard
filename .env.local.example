# Copy to `.env.local` (gitignored) and fill in. The same names must be set as
# repo variables in GitHub Actions for production builds.

# URL of the Cloudflare Worker that proxies the chat to OpenRouter. When set, a
# third "Demo (no key — free tier)" provider lights up in the chat settings
# and becomes the default so visitors don't need their own API key.
# Format: https://<your-worker>.workers.dev/chat   (note the /chat path)
# Leave empty to disable the demo provider.
NEXT_PUBLIC_DEMO_WORKER_URL=
